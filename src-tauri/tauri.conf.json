{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JArcade",
  "version": "0.1.0",
  "identifier": "com.jarcade.launcher",
  "build": {
    "beforeDevCommand": "./build.sh && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "./build.sh && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "tauri-app",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/freej2me.jar"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
